{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewNeeded",
  "description": "Elements requiring human review, with page+element precision.",
  "type": "object",
  "required": ["document_id", "filename", "items", "summary"],
  "properties": {
    "document_id": { "type": "string" },
    "filename": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["block_id", "page_num", "block_type", "category", "severity", "reason"],
        "properties": {
          "block_id": { "type": "string" },
          "page_num": { "type": "integer", "minimum": 0 },
          "block_type": {
            "type": "string",
            "enum": ["heading", "paragraph", "table", "image", "list", "form_field"]
          },
          "category": {
            "type": "string",
            "enum": [
              "low_confidence_ocr",
              "complex_table",
              "missing_alt_text",
              "ambiguous_heading",
              "form_field",
              "axe_violation",
              "gate_soft_fail"
            ]
          },
          "severity": { "type": "string", "enum": ["critical", "serious", "moderate", "minor"] },
          "reason": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_items", "by_category", "by_severity"],
      "properties": {
        "total_items": { "type": "integer" },
        "by_category": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "by_severity": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      }
    }
  }
}
